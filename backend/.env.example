# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
# Always include the database name (required for MongoDB Compass visibility)
MONGODB_URI=mongodb://localhost:27017/ai-placement-copilot
# Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-placement-copilot

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Services — Gemini (multi-key fallback on rate limit / errors)
# Option A: numbered keys (recommended for 7 keys)
GEMINI_API_KEY=your-gemini-api-key-1
GEMINI_API_KEY_2=your-gemini-api-key-2
GEMINI_API_KEY_3=your-gemini-api-key-3
GEMINI_API_KEY_4=your-gemini-api-key-4
GEMINI_API_KEY_5=your-gemini-api-key-5
GEMINI_API_KEY_6=your-gemini-api-key-6
GEMINI_API_KEY_7=your-gemini-api-key-7
# Option B: comma-separated list (alternative to numbered keys)
# GEMINI_API_KEYS=key1,key2,key3,key4,key5,key6,key7
GEMINI_MODEL=gemini-2.5-flash
# Required for voice/video transcription (OpenAI Whisper API)
WHISPER_API_KEY=your-openai-whisper-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Job APIs
# JSearch — use OpenWeb Ninja key (ak_...) from https://app.openwebninja.com/api/jsearch
# Or RapidAPI key from https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your-jsearch-api-key
# Adzuna India — https://developer.adzuna.com/
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
DEFAULT_JOB_COUNTRY=India

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend
FRONTEND_URL=http://localhost:5173
# Production (comma-separated if you also test locally):
# FRONTEND_URL=https://career-os-five-rho.vercel.app,http://localhost:5173
SESSION_SECRET=your-session-secret

# Redis (optional — falls back to in-memory cache)
# REDIS_URL=redis://localhost:6379

# Sentry (optional error monitoring)
# SENTRY_DSN=https://your-sentry-dsn

# SMTP (optional — verification emails logged in dev if unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=CareerOS <noreply@careeros.app>

# Dev scripts (optional — scripts/feature-check.mjs)
# API_BASE=http://localhost:5000/api
# FEATURE_CHECK_EMAIL=featurecheck@test.com
# FEATURE_CHECK_PASSWORD=YourTest@Pass1
